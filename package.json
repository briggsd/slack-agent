{
  "name": "slackbot",
  "version": "0.1.0",
  "description": "Slack gateway for Claude sessions",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "check": "tsc --noEmit && npm --prefix runner run check && vitest run",
    "test": "vitest run"
  },
  "dependencies": {
    "@slack/bolt": "^3.22.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
