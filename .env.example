# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-your-app-token-here

# Session idle timeout in milliseconds (default: 600000 = 10 minutes)
# IDLE_TIMEOUT_MS=600000

# Volume GC: remove a session's workspace volume + row after this much inactivity
# (default: 604800000 = 7 days), and how often the sweep runs (default: 3600000 = 1 hour)
# VOLUME_TTL_MS=604800000
# VOLUME_GC_INTERVAL_MS=3600000

# Path to the SQLite session database (default: .data/sessions.db)
# SESSION_DB_PATH=.data/sessions.db

# ── Runner backend ────────────────────────────────────────────────────────────

# Runner backend: "fake" (default, for development) or "docker" (production)
# RUNNER_BACKEND=docker

# Anthropic API key — required when RUNNER_BACKEND=docker
# Passed to the container via -e ANTHROPIC_API_KEY (value never appears in argv)
# ANTHROPIC_API_KEY=sk-ant-...

# Docker image for the runner container (default: slackbot-runner:latest)
# Build with: docker build -t slackbot-runner runner/
# RUNNER_IMAGE=slackbot-runner:latest

# Time to wait for the container's "ready" handshake, in ms (default: 30000)
# RUNNER_READY_TIMEOUT_MS=30000

# Per-turn timeout in ms (default: 300000 = 5 minutes)
# RUNNER_TURN_TIMEOUT_MS=300000

# Grace period before SIGKILL on session dispose, in ms (default: 5000)
# RUNNER_KILL_GRACE_MS=5000

# Container resource limits
# RUNNER_MEMORY=512m
# RUNNER_CPUS=1.0
# RUNNER_PIDS_LIMIT=256

# ── One-shot repo tasks ───────────────────────────────────────────────────────
# Triggers: @slackbot task github:owner/repo <instruction>  (supervised — pauses at a
#           plan-approval gate; reply approve / cancel / changes in-thread)
#           @slackbot exec github:owner/repo <instruction>  (fire-and-forget — no gate)
# Active for real repos only under RUNNER_BACKEND=docker; faked otherwise.

# Bot-account token for one-shot GitHub tasks. Stays gateway-side — never enters
# the agent sandbox. Required for `task`/`exec github:…`; without it they error.
# GITHUB_BOT_TOKEN=ghp_...

# Same, for GitLab (provider not yet implemented).
# GITLAB_BOT_TOKEN=glpat-...

# How long a supervised (task) run waits at the plan gate before abandoning (default 15 min).
# GATE_TIMEOUT_MS=900000

# Image for the ephemeral credentialed git nodes (default: slackbot-runner:latest)
# GIT_IMAGE=slackbot-runner:latest

# Exact GitHub owner/name slugs the conversational clone_repo tool may clone.
# Empty/unset denies model-chosen clones.
# Entries must be bare owner/name slugs (no URL, no .git, no extra path);
# an invalid entry fails startup.
# CLONE_REPO_ALLOWLIST=owner/repo,acme/widgets

# Optional override for the lint/test check commands. When unset, checks auto-detect:
# `npm run <lint|test> --if-present` if package.json exists, otherwise skip. Set these
# to run a different command (e.g. for a non-npm repo). Run via `sh -c` in the workdir.
# ONESHOT_LINT_CMD=make lint
# ONESHOT_TEST_CMD=make test

# Per-repo override map (JSON): repo slug → { lint, test }. Takes precedence over the
# global ONESHOT_LINT_CMD/ONESHOT_TEST_CMD above; a missing repo or kind falls through to
# the global override, then auto-detect. Malformed JSON is ignored (no overrides).
# ONESHOT_CHECK_CMDS={"acme/api":{"lint":"ruff check","test":"pytest"},"acme/web":{"test":"npm test"}}
